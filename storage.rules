rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function currentUserExists() {
      return signedIn() &&
        firestore.exists(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function currentUserDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function isActiveUser() {
      return currentUserExists() &&
        currentUserDoc().data.status == "active";
    }

    function isAdminOrManager() {
      return isActiveUser() &&
        (currentUserDoc().data.role == "admin" ||
         currentUserDoc().data.role == "manager");
    }

    function isImageFile() {
      return request.resource != null &&
             request.resource.contentType.matches("image/.*");
    }

    function sizeAllowed() {
      return request.resource != null &&
             request.resource.size < 2 * 1024 * 1024;
    }

    match /checksheet-images/{uid}/{submissionId}/{fileName} {
      allow read: if (signedIn() && request.auth.uid == uid) || isAdminOrManager();

      allow write: if isActiveUser() &&
                   request.auth.uid == uid &&
                   isImageFile() &&
                   sizeAllowed();

      allow delete: if (signedIn() && request.auth.uid == uid) || isAdminOrManager();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
