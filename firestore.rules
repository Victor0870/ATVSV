rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserExists() {
      return signedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return currentUserDoc().data.role.lower();
    }

    function userStatus() {
      return currentUserDoc().data.status.lower();
    }

    function isActiveUser() {
      return currentUserExists() &&
             userStatus() == "active";
    }

    function isAdminOrManager() {
      return isActiveUser() &&
             (userRole() == "admin" || userRole() == "manager");
    }

    function isAdmin() {
      return isActiveUser() &&
             userRole() == "admin";
    }

    // User profiles are created only via Cloud Functions (completeRegistration).
    match /users/{userId} {
      allow read: if signedIn() &&
                  (request.auth.uid == userId || isAdminOrManager());

      allow create: if false;

      allow update: if false;

      allow delete: if isAdmin() &&
                    resource.data.role.lower() != "admin";
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    function isSameKhuVuc(data) {
      return isActiveUser() &&
             data.khuVuc == currentUserDoc().data.khuVuc;
    }

    match /submissions/{submissionId} {
      allow read: if isAdminOrManager() ||
                  (signedIn() && resource.data.uid == request.auth.uid) ||
                  isSameKhuVuc(resource.data);

      allow create: if isActiveUser() &&
                    request.resource.data.uid == request.auth.uid &&
                    request.resource.data.email == request.auth.token.email &&
                    request.resource.data.taiKhoan == currentUserDoc().data.taiKhoan &&
                    request.resource.data.hoTen == currentUserDoc().data.hoTen &&
                    request.resource.data.khuVuc == currentUserDoc().data.khuVuc;

      allow update, delete: if isAdminOrManager();
    }

    match /checklistItems/{itemId} {
      allow read: if isActiveUser() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /checklistCategories/{categoryId} {
      allow read: if isActiveUser() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /branches/{branchId} {
      allow read: if isActiveUser() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /remediationIssues/{issueId} {
      allow read: if isAdminOrManager() ||
                  isSameKhuVuc(resource.data);

      allow create: if isActiveUser() &&
                    request.resource.data.uid == request.auth.uid &&
                    request.resource.data.status == "open" &&
                    request.resource.data.plan == "" &&
                    request.resource.data.action == "" &&
                    request.resource.data.responsible == "";

      allow update: if isAdminOrManager();

      allow delete: if isAdmin();
    }
  }
}
