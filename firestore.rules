rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserExists() {
      return signedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return currentUserDoc().data.role.lower();
    }

    function userStatus() {
      return currentUserDoc().data.status.lower();
    }

    function isActiveUser() {
      return currentUserExists() &&
             userStatus() == "active";
    }

    function isAdminOrManager() {
      return isActiveUser() &&
             (userRole() == "admin" || userRole() == "manager");
    }

    function isAdmin() {
      return isActiveUser() &&
             userRole() == "admin";
    }

    function isSelfRegistration(userId) {
      return signedIn() &&
             request.auth.uid == userId &&
             request.resource.data.uid == userId &&
             request.resource.data.role == "user" &&
             request.resource.data.status in ["pending", "inactive"];
    }

    match /users/{userId} {
      allow read: if signedIn() &&
                  (request.auth.uid == userId || isAdminOrManager());

      allow create: if isSelfRegistration(userId) || isAdmin();

      allow update, delete: if isAdmin();
    }

    match /submissions/{submissionId} {
      allow read: if isAdminOrManager() ||
                  (signedIn() && resource.data.uid == request.auth.uid);

      allow create: if isActiveUser() &&
                    request.resource.data.uid == request.auth.uid &&
                    request.resource.data.email == request.auth.token.email &&
                    request.resource.data.taiKhoan == currentUserDoc().data.taiKhoan &&
                    request.resource.data.hoTen == currentUserDoc().data.hoTen &&
                    request.resource.data.khuVuc == currentUserDoc().data.khuVuc;

      allow update, delete: if isAdminOrManager();
    }

    match /checklistItems/{itemId} {
      allow read: if isActiveUser() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /checklistCategories/{categoryId} {
      allow read: if isActiveUser() || isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}
